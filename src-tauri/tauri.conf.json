{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Council",
  "version": "0.1.0",
  "identifier": "com.council.governance",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "",
    "beforeBuildCommand": "cd frontend && pnpm install && pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Council — Agent Governance",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; img-src 'self' data: blob: http://127.0.0.1:* http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/council-backend"
    ]
  }
}
